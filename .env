# Optional: document only — Razorpay Checkout `key_id` is returned from Edge Functions
# using `RAZORPAY_KEY_ID` on the server; you do not need a VITE_ key for checkout.

# Supabase Edge Function secrets (Dashboard → Project Settings → Edge Functions):
# RAZORPAY_KEY_ID=         # same key id as in Razorpay Dashboard (also returned to the client for Checkout.js)
# RAZORPAY_KEY_SECRET=     # never expose to the browser
# RAZORPAY_WEBHOOK_SECRET= # Webhook signing secret from Razorpay Dashboard
# SUPABASE_SERVICE_ROLE_KEY=  # required for payment fulfilment (if not auto-injected in your setup)
#
# Nimbuspost (optional; see docs/NIMBUSPOST.md):
# NIMBUSPOST_API_BASE=https://api.nimbuspost.com/v1
# NIMBUSPOST_CREATE_PATH=shipments
# NIMBUSPOST_WEBHOOK_SECRET=  # if set, webhook requires ?secret= or x-nimbus-webhook-secret header
